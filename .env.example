# Copy to .env.local and fill in values from your Supabase project
# settings (Project Settings → API). Never commit .env.local.
#
# Note: the publishable key is designed to ship in the browser bundle —
# RLS is the security boundary — but we still keep real values out of
# the repo as a matter of policy.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxxxxxxxxxxxxxxxxxxx

# Public dashboard URL used in outgoing emails (credentials, order
# notifications). When running on localhost the lib falls back to
# https://chipurobo.com so links in emails are always clickable.
# Override via Vercel env vars per environment if needed.
# VITE_DASHBOARD_URL=https://chipurobo.com
