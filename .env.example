# Copy this file to `.env.local` and fill in the values from `supabase status`.
# The `.env.local` file is gitignored.

# --- Supabase ---
# After `supabase start`, run `supabase status` and copy these in:
VITE_SUPABASE_URL=http://localhost:54321
VITE_SUPABASE_ANON_KEY=

# In production, set these to your Supabase Cloud project's values via
# the hosting provider's env-var dashboard (Vercel/Netlify/etc).
